#Node
API_PORT=3006
API_URL=http://localhost

# Día calendario de negocio (capturas, historial "hoy", carpetas uploads/)
APP_TIMEZONE=Australia/Sydney

# CORS Allow FrondEnd
NODE_ENV=development
CORS_ORIGINS=https://localhost:5173,http://localhost:5173,http://127.0.0.1:5173
# En desarrollo: permitir https://192.168.x.x:5173 (red local)
CORS_ALLOW_LAN=true


# Folders
UPLOADS_DIR=uploads
PROCESSED_DIR=procesed

# MySQL (local: localhost | Docker/producción en app_network: mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=5492Allg
DB_NAME=uefn
# Reintentos al arrancar si MySQL aún no está listo (deploy CI/CD)
DB_CONNECT_RETRIES=30
DB_CONNECT_DELAY_MS=2000


# Status table emotion_captures
PROCESSED_ESTADO=procesado
NEW_ESTADO=nuevo

# --- Rate limiting (anti-abuso / robots) — ver config/apiSecurity.js ---
# Activa o desactiva todos los límites
RATE_LIMIT_ENABLED=true
# Si la API va detrás de nginx, usa la IP real (X-Forwarded-For)
RATE_LIMIT_TRUST_PROXY=true
# Ventana de tiempo común para todos los contadores (milisegundos). 60000 = 1 minuto
RATE_LIMIT_WINDOW_MS=60000
# IPs que no se limitan (coma separada). Ej: n8n en el mismo servidor
RATE_LIMIT_WHITELIST_IPS=127.0.0.1,::1
# Techo total por IP en toda la API (excepto /health)
RATE_LIMIT_GLOBAL_MAX=200
# POST /api/history — ~1 registro/segundo con cámara activa (~60/min) + margen
RATE_LIMIT_HISTORY_POST_MAX=100
# POST /api/captures — subida de fotos (captura automática cada ~2.5s o más)
RATE_LIMIT_CAPTURES_POST_MAX=18
# PATCH /api/captures/:id/processed — flujo n8n / procesado
RATE_LIMIT_CAPTURES_PATCH_MAX=60
# GET /api/history/* y GET /api/captures/*
RATE_LIMIT_API_GET_MAX=120
# GET /media/* — imágenes y miniaturas
RATE_LIMIT_MEDIA_GET_MAX=240