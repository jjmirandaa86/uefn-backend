        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ estadoProcesamiento: $json.estadoFinal, rutaAlmacenamientoDivertida: $json.rutaAlmacenamientoDivertida, rutaAbsolutaDivertida: $json.rutaAbsolutaDivertida }) }}",
        "options": {}
      },
